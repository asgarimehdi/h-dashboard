# Copy this file to .env and fill in values
# Then run: php artisan key:generate

APP_NAME="Health Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://h-dashboard.test

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=h_dashboard
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

# Zabbix API (IT Monitoring)
ZABBIX_URL=https://zabbix.example.com/api_jsonrpc.php
ZABBIX_TOKEN=your_zabbix_api_token_here

# Map tile server
TILE_SERVER_IP=127.0.0.1

# Sanctum (mobile app)
SANCTUM_STATEFUL_DOMAINS=h-dashboard.test